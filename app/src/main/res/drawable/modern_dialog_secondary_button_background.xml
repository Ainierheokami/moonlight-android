<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2C3949" />
            <stroke
                android:width="1dp"
                android:color="#46586C" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#202A36" />
            <stroke
                android:width="1dp"
                android:color="#374658" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</selector>
