<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#263241" />
            <stroke
                android:width="1dp"
                android:color="#3E5166" />
            <corners android:radius="7dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#18212C" />
            <stroke
                android:width="1dp"
                android:color="#2A3747" />
            <corners android:radius="7dp" />
        </shape>
    </item>
</selector>
