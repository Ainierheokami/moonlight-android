<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#3A2027" />
            <stroke
                android:width="1dp"
                android:color="#D55F76" />
            <corners android:radius="7dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#251A22" />
            <stroke
                android:width="1dp"
                android:color="#66303D" />
            <corners android:radius="7dp" />
        </shape>
    </item>
</selector>
