<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1016"
    tools:context=".preferences.StreamSettings">

    <LinearLayout
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/pc_toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/settingsBackButton"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/pc_toolbar_button_background"
            android:contentDescription="@android:string/cancel"
            android:padding="12dp"
            android:preferKeepClear="true"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_media_previous" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_stream_settings"
                android:textColor="#F5F8FC"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/subtitle_stream_settings"
                android:textColor="#8FA0B2"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/stream_settings"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/settingsToolbar"
        android:background="@drawable/settings_panel_background"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp" />
</RelativeLayout>
