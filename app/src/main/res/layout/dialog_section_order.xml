<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/modern_dialog_background"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="22dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/sectionOrderTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F5F8FC"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sectionOrderSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="2dp"
        android:textColor="#B8C4D2"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sectionOrderList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:nestedScrollingEnabled="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/sectionOrderResetButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/modern_dialog_secondary_button_background"
            android:minWidth="88dp"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:stateListAnimator="@null"
            android:text="@string/game_menu_section_order_reset"
            android:textAllCaps="false"
            android:textColor="#DCE6F1"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/sectionOrderDoneButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/modern_dialog_primary_button_background"
            android:minWidth="88dp"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:stateListAnimator="@null"
            android:text="@android:string/ok"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
