<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="176dp"
    android:layout_margin="8dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#18202A"
    app:cardCornerRadius="8dp"
    app:cardElevation="5dp"
    app:cardUseCompatPadding="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/pc_card_background">

        <ImageView
            android:id="@+id/grid_image"
            android:layout_width="match_parent"
            android:layout_height="124dp"
            android:background="@drawable/pc_card_image_placeholder"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/pc_placeholder_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="30dp"
            android:alpha="0.34"
            android:src="@drawable/ic_computer" />

        <ImageView
            android:id="@+id/grid_overlay"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="#66000000"
            android:padding="8dp" />

        <ProgressBar
            android:id="@+id/grid_spinner"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:indeterminate="true" />

        <LinearLayout
            android:id="@+id/pc_card_info"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_gravity="bottom"
            android:background="@drawable/pc_card_info_scrim"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <TextView
                android:id="@+id/grid_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#F6FAFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pc_address_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textColor="#B9C5D1"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/pc_status_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/pc_status_dot_offline" />

                <TextView
                    android:id="@+id/pc_status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#DCE6F1"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pairing_info_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E60B1016"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/pairing_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="#F6FAFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/cancel_pairing_button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_background_red"
                android:minWidth="92dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>
