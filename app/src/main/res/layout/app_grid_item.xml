<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="172dp"
    android:layout_height="230dp"
    app:cardBackgroundColor="#18202A"
    app:cardCornerRadius="8dp"
    app:cardElevation="5dp"
    app:cardUseCompatPadding="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_card_background">

        <ImageView
            android:id="@+id/grid_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/pc_card_image_placeholder"
            android:cropToPadding="false"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/app_running_badge"
            android:layout_width="44dp"
            android:layout_height="5dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="10dp"
            android:background="@drawable/app_running_badge_background"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/grid_overlay"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_margin="10dp"
            android:background="#88000000"
            android:padding="9dp" />

        <LinearLayout
            android:id="@+id/app_card_info"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="bottom"
            android:background="@drawable/app_card_title_scrim"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/grid_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="2"
                android:textColor="#F6FAFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/app_state_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#B9C5D1"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>
